# Database (SQLite by default; use PostgreSQL in production)
DATABASE_URL=sqlite:///./app.db

# JWT
SECRET_KEY=your-secret-key-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ENVIRONMENT=development

# Comma-separated. For local dev with any origin use: CORS_ORIGINS=*
# (credentials disabled automatically when *). Native mobile apps ignore CORS.
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://127.0.0.1:8081

# Optional seed admin (disabled by default; enable only on first bootstrap)
SEED_ADMIN_ENABLED=false
SEED_ADMIN_EMAIL=
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=

# Firebase (optional – for Google/Microsoft/Apple login via POST /auth/firebase)
# Path to your Firebase service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=path/to/firebase-service-account.json

# Stripe (subscriptions – use env vars, never commit secret key)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_1T9WELJmMTsz75BuDfAUilZr
STRIPE_PRICE_PRO=price_1T9WK9JmMTsz75Bu0WaqAUSz
STRIPE_PRICE_PRO_PLUS=price_1T9WLNJmMTsz75BuPKntPszC
FRONTEND_URL=http://localhost:3000

# Azure AD / Microsoft SSO (optional – for POST /auth/azure-ad; companies can use corporate accounts)
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_TENANT_ID=your-tenant-id

# Azure Blob Storage (for file/image uploads – use env, never commit connection string)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=xxx;AccountKey=xxx;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=uploads
